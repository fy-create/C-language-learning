{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug C Program",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/3",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "lldb",
            "targetArchitecture": "arm64", // 指定目标架构
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for lldb",
                    "text": "settings set target.max-memory-read 1048576",
                    "ignoreFailures": true
                }
            ],
        }
    ]
}